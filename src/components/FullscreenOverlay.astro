---
---
<div id="fullscreen-overlay" class="fullscreen-overlay">
  <div class="fs-container">
    <div class="fs-header">
      <span class="fs-label panel-label">Berikutnya</span>
      <h2 id="fs-next-prayer" class="fs-title">-</h2>
      <span id="fs-next-time" class="fs-time">--:--</span>
    </div>
    
    <div class="fs-body">
      <div id="fs-countdown" class="fs-timer">--:--:--</div>
    </div>
    
    <div class="fs-footer">
      <p id="fs-countdown-note" class="fs-note">Mengambil jadwal terbaru.</p>
      <div class="fs-actions countdown-actions">
        <button class="icon-button" id="fs-theme-toggle" type="button" title="Ganti tema">
          <svg class="theme-icon theme-icon--dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
          <svg class="theme-icon theme-icon--light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
        </button>
        <button class="icon-button" id="fs-rotate-toggle" type="button" title="Putar layar">
          <svg class="rotate-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
            <path d="M3 3v5h5"></path>
          </svg>
        </button>
        <button class="icon-button" id="fs-fullscreen-toggle" type="button" title="Keluar layar penuh">
          <svg class="fullscreen-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 3v6H3M15 3v6h6M21 15h-6v6M3 15h6v6"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .fullscreen-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: var(--bg);
    place-items: center;
    overflow: hidden;
  }

  /* Add hero-style background for consistency */
  .fullscreen-overlay::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(160deg, rgba(15, 107, 100, 0.15), transparent 50%),
      linear-gradient(20deg, rgba(217, 156, 43, 0.1), transparent 50%);
    z-index: -1;
  }

  :global(body.countdown-fullscreen) .fullscreen-overlay {
    display: grid;
  }

  .fs-container {
    width: min(1100px, 90vw);
    text-align: center;
    background: var(--glass);
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    border: 1px solid var(--glass-border);
    border-radius: 32px;
    padding: clamp(32px, 6vw, 80px);
    display: flex;
    flex-direction: column;
    gap: clamp(32px, 5vw, 60px);
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.4);
    position: relative;
    z-index: 10;
  }

  .fs-label {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 800;
    margin-bottom: 8px;
    display: block;
  }

  .fs-title {
    font-size: clamp(2.8rem, 9vw, 6.5rem);
    font-weight: 950;
    margin: 0;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .fs-time {
    font-size: clamp(1.4rem, 4vw, 2.2rem);
    font-weight: 700;
    color: var(--primary);
    display: block;
    margin-top: 12px;
  }

  :global(body.theme-dark) .fs-time {
    color: #f0c66e;
  }

  .fs-timer {
    font-size: clamp(4.5rem, 18vw, 16rem);
    font-weight: 900;
    font-variant-numeric: tabular-nums;
    line-height: 0.85;
    letter-spacing: -0.03em;
  }

  .fs-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  .fs-note {
    font-size: clamp(0.9rem, 1.8vw, 1.15rem);
    opacity: 0.6;
    margin: 0;
  }

  .fs-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
  }

  /* LANDSCAPE OPTIMIZATION */
  @media (orientation: landscape) {
    .fs-container {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      text-align: left;
      padding: clamp(24px, 6vh, 60px);
      gap: clamp(40px, 8vw, 100px);
      width: min(1400px, 94vw);
      height: auto;
      max-height: 92vh;
    }

    .fs-header {
      flex: 0 1 auto;
    }

    .fs-body {
      flex: 0 1 auto;
      display: flex;
      justify-content: center;
    }

    .fs-footer {
      flex: 0 1 auto;
      align-items: flex-start;
      text-align: left;
    }

    .fs-actions {
      justify-content: flex-start;
    }
  }

  @media (orientation: landscape) and (max-height: 600px) {
    .fs-container {
      gap: 40px;
      padding: 24px 48px;
    }
    .fs-title { font-size: clamp(1.8rem, 12vh, 4rem); }
    .fs-timer { font-size: clamp(3.5rem, 45vh, 10rem); }
  }
</style>
