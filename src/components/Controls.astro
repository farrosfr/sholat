---
---
<section class="controls" aria-label="Pilihan lokasi">
  <div class="region-selector">
    <button type="button" class="region-pill active" id="region-id" data-region="id">Indonesia</button>
    <button type="button" class="region-pill" id="region-intl" data-region="intl">Global</button>
  </div>
  <form class="search" id="search-form">
    <label for="city-input">Cari kota/kabupaten</label>
    <div class="search__group">
      <input id="city-input" name="city" type="search" autocomplete="off" placeholder="Contoh: Gresik, Surabaya, Bandung">
      <button type="submit">Cari</button>
    </div>
  </form>
  <button class="location-button" id="location-button" type="button">Gunakan lokasi saya</button>
</section>

<section class="status" id="status" role="status"></section>

<section class="results" aria-label="Hasil pencarian">
  <div class="result-list" id="result-list"></div>
</section>
